{
    "openapi": "3.0.0",
    "info": {
      "title": "Order API IDL",
      "version": "1.0.0",
      "description": "订单相关的数据模型定义"
    },
    "components": {
      "schemas": {
        "Order": {
          "type": "object",
          "required": ["id", "orderNumber", "customerId", "status", "totalAmount", "createdAt"],
          "properties": {
            "id": {
              "type": "string",
              "description": "订单唯一标识",
              "example": "ord_1234567890"
            },
            "orderNumber": {
              "type": "string",
              "description": "订单号（用户可见）",
              "example": "NO202604120001"
            },
            "customerId": {
              "type": "string",
              "description": "客户ID",
              "example": "cus_9876543210"
            },
            "status": {
              "type": "string",
              "description": "订单状态",
              "enum": ["pending", "paid", "processing", "shipped", "delivered", "cancelled", "refunded"],
              "example": "paid"
            },
            "totalAmount": {
              "type": "number",
              "format": "double",
              "description": "订单总金额",
              "example": 299.99
            },
            "currency": {
              "type": "string",
              "description": "货币代码",
              "default": "CNY",
              "example": "CNY"
            },
            "items": {
              "type": "array",
              "description": "订单商品列表",
              "items": {
                "$ref": "#/components/schemas/OrderItem"
              }
            },
            "shippingAddress": {
              "$ref": "#/components/schemas/Address"
            },
            "billingAddress": {
              "$ref": "#/components/schemas/Address"
            },
            "paymentInfo": {
              "$ref": "#/components/schemas/PaymentInfo"
            },
            "createdAt": {
              "type": "string",
              "format": "date-time",
              "description": "订单创建时间",
              "example": "2026-04-12T10:30:00Z"
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time",
              "description": "订单更新时间"
            },
            "remarks": {
              "type": "string",
              "description": "订单备注",
              "maxLength": 500
            }
          }
        },
        "OrderItem": {
          "type": "object",
          "required": ["productId", "productName", "quantity", "unitPrice", "subtotal"],
          "properties": {
            "productId": {
              "type": "string",
              "description": "商品ID",
              "example": "prod_123"
            },
            "productName": {
              "type": "string",
              "description": "商品名称",
              "example": "无线鼠标"
            },
            "sku": {
              "type": "string",
              "description": "SKU编码"
            },
            "quantity": {
              "type": "integer",
              "minimum": 1,
              "example": 2
            },
            "unitPrice": {
              "type": "number",
              "format": "double",
              "description": "单价",
              "example": 129.99
            },
            "subtotal": {
              "type": "number",
              "format": "double",
              "description": "小计金额",
              "example": 259.98
            },
            "discount": {
              "type": "number",
              "format": "double",
              "description": "单品折扣金额",
              "default": 0
            }
          }
        },
        "Address": {
          "type": "object",
          "required": ["receiverName", "phone", "country", "province", "city", "detailAddress"],
          "properties": {
            "receiverName": {
              "type": "string",
              "description": "收货人姓名"
            },
            "phone": {
              "type": "string",
              "description": "联系电话"
            },
            "country": {
              "type": "string",
              "description": "国家",
              "example": "中国"
            },
            "province": {
              "type": "string",
              "description": "省/州"
            },
            "city": {
              "type": "string",
              "description": "城市"
            },
            "district": {
              "type": "string",
              "description": "区/县"
            },
            "detailAddress": {
              "type": "string",
              "description": "详细地址"
            },
            "postalCode": {
              "type": "string",
              "description": "邮政编码"
            }
          }
        },
        "PaymentInfo": {
          "type": "object",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["credit_card", "debit_card", "alipay", "wechat_pay", "bank_transfer", "cash_on_delivery"],
              "description": "支付方式"
            },
            "paymentStatus": {
              "type": "string",
              "enum": ["unpaid", "pending", "paid", "failed", "refunded"],
              "description": "支付状态"
            },
            "transactionId": {
              "type": "string",
              "description": "第三方支付交易ID"
            },
            "paidAt": {
              "type": "string",
              "format": "date-time",
              "description": "支付完成时间"
            },
            "amount": {
              "type": "number",
              "format": "double",
              "description": "实际支付金额"
            }
          }
        },
        "CreateOrderRequest": {
          "type": "object",
          "required": ["customerId", "items", "shippingAddress"],
          "properties": {
            "customerId": { "type": "string" },
            "items": {
              "type": "array",
              "items": { "$ref": "#/components/schemas/OrderItem" }
            },
            "shippingAddress": { "$ref": "#/components/schemas/Address" },
            "billingAddress": { "$ref": "#/components/schemas/Address" },
            "paymentMethod": { "type": "string" },
            "remarks": { "type": "string" }
          }
        },
        "UpdateOrderRequest": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "shippingAddress": { "$ref": "#/components/schemas/Address" },
            "remarks": { "type": "string" }
          }
        }
      }
    }
  }